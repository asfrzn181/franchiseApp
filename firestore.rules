rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fungsi bantuan cek login
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      // PENTING: Izinkan user (termasuk staff baru) membuat profilnya sendiri
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Izinkan baca & update jika itu miliknya sendiri
      allow read, update: if isAuthenticated() && request.auth.uid == userId;

      // OWNER: Izinkan Owner membaca data staff yang memiliki outlet_id yang sama
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.outlet_id == resource.data.outlet_id;
    }

    match /outlets/{outletId} {
      // Anggota outlet bisa baca data gerainya
      allow read: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.outlet_id == outletId;
      
      // OWNER: Bisa baca outlet yang ia miliki (owner_id), termasuk owner baru yang belum punya outlet_id
      allow read: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        resource.data.owner_id == request.auth.uid;

      // Owner yang sudah punya outlet bisa edit outlet aktifnya
      allow update, delete: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        resource.data.owner_id == request.auth.uid;

      // Owner bisa membuat outlet baru (termasuk owner baru yang belum punya outlet_id)
      allow create: if isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner' &&
        request.resource.data.owner_id == request.auth.uid;
    }

    // Aturan Global untuk sub-koleksi di masa depan (ingredients, sales, dll)
    match /{allPaths=**} {
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.outlet_id != null;
    }
  }
}